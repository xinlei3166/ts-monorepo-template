{
  "name": "ts-monorepo-template",
  "version": "0.1.0",
  "private": true,
  "description": "",
  "keywords": [
    "monorepo",
    "template",
    "typescript"
  ],
  "homepage": "https://github.com/xinlei3166/ts-monorepo-template#readme",
  "bugs": {
    "url": "https://github.com/xinlei3166/ts-monorepo-template/issues"
  },
  "license": "MIT",
  "author": "君惜",
  "repository": {
    "type": "git",
    "url": "https://github.com/xinlei3166/ts-monorepo-template.git"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "prepare": "simple-git-hooks",
    "test": "vp test",
    "copyfiles": "node ./scripts/copyfiles.js",
    "format": "vp fmt",
    "format:check": "vp fmt --check",
    "lint": "vp lint",
    "lint:fix": "vp lint --fix"
  },
  "devDependencies": {
    "@rollup/plugin-buble": "^1.0.3",
    "@rollup/plugin-commonjs": "^25.0.7",
    "@rollup/plugin-json": "^6.0.1",
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^5.0.4",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.5",
    "@types/node": "^20.8.7",
    "@yunquejs/release": "^0.1.9",
    "conventional-changelog-cli": "^4.1.0",
    "lint-staged": "^15.0.2",
    "npm-run-all": "^4.1.5",
    "picocolors": "latest",
    "rollup": "^4.1.4",
    "simple-git-hooks": "latest",
    "tslib": "^2.8.1",
    "tsx": "latest",
    "typescript": "^6.0.0",
    "vite-plus": "catalog:",
    "vitest": "catalog:"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm exec lint-staged --concurrent false",
    "commit-msg": "pnpm exec tsx scripts/verifyCommit.ts $1"
  },
  "lint-staged": {
    "*": [
      "vp check --fix --no-error-on-unmatched-pattern"
    ]
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": "^11.0.0",
      "onFail": "download"
    }
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
